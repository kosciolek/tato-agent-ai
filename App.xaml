<Application x:Class="AgentReadonly.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F7F7F5"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrushMuted" Color="#D6D8D3"/>
    <SolidColorBrush x:Key="TextBrush" Color="#1F2528"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#5E6A70"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#276B8E"/>
    <SolidColorBrush x:Key="ReadonlyBrush" Color="#2F6F4E"/>
  </Application.Resources>
</Application>
